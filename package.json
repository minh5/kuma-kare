{
  "name": "kuma-kare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "VITE_BASE_PATH=${VITE_BASE_PATH:-/} vite build",
    "build:kuma": "VITE_BASE_PATH=/kuma vite build",
    "build:root": "VITE_BASE_PATH=/ vite build",
    "preview": "vite preview",
    "deploy": "npm run build:kuma && wrangler pages deploy dist && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.1"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "marked": "^18.0.5"
  }
}
