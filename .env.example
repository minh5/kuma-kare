# ---- Frontend (Vite build-time) ----
# Drives Vite `base` and React Router `basename`. Set to "/kuma" or "/".
VITE_BASE_PATH=/kuma

# ---- Worker (runtime) ----
# Drives route prefix, cookie path, redirect URI construction.
BASE_PATH=/kuma

# Google OAuth 2.0 credentials (Cloudflare Worker secrets).
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI must be: https://<your-domain><BASE_PATH>/api/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# HS256 JWT signing key. Generate with: openssl rand -hex 32
JWT_SECRET=generate-a-32-byte-hex-secret-here

# Anthropic API key for Claude Haiku 4.5.
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated allowlist of authorized caretaker emails.
ALLOWED_EMAILS=caretaker1@example.com,caretaker2@example.com
